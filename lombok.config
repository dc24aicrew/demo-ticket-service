# This file configures how Lombok behaves in this project

# Since we are using Jakarta EE (Spring Boot 3.x), use the Jakarta annotations
lombok.addJakartaGeneratedAnnotation = true
lombok.addJavaxGeneratedAnnotation = false

# Make generated toString methods call directly on super's toString implementation, 
# instead of inspecting the fields of the superclass
lombok.toString.callSuper = call

# Getter method prefix for boolean fields - if true, uses 'is' prefix, if false uses 'get' prefix
lombok.getter.noIsPrefix = false

# Specify which annotations should be copied to generated methods
# (useful when you have annotations that should be applied to generated getters/setters)
lombok.copyableAnnotations += org.springframework.lang.NonNull
lombok.copyableAnnotations += jakarta.validation.constraints.NotNull

# Configure @Builder to generate a singular method for collection fields
# (e.g., for a field 'List<String> roles', it will generate roleS() and role(String) methods)
lombok.singular.auto = true

# Remove any warning when using experimental features
lombok.experimental.flagUsage = allow
